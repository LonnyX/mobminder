# =================================================
# Mobi Docker Environment Configuration
# =================================================
# Copy this file to .env and customize as needed
# cp .env.example .env

# =================================================
# MySQL Database Configuration
# =================================================
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smsgateaway
MYSQL_USER=queuing_daemon
MYSQL_PASSWORD=1970

# =================================================
# Application Ports
# =================================================
# Each application runs on its own port
APP06_PORT=8081
ELEARNING_PORT=8082
MOBCOM_PORT=8083
CONTRACTING_PORT=8084
MOBMINDER_PORT=8085
BOOKING_PORT=8086

# =================================================
# PHP Configuration
# =================================================
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=6
PHP_UPLOAD_MAX_FILESIZE=40M
PHP_POST_MAX_SIZE=40M

# =================================================
# Application Settings
# =================================================
TZ=Europe/Brussels

# =================================================
# Development / Production Mode
# =================================================
# APP_ENV=development
# APP_DEBUG=true
