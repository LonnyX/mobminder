# =========================
*.pid

# =========================
# Temporary / backup files
# =========================
*.tmp
*.bak
*.swp
*~

# =========================
# Binary / compiled executables
# =========================
*.exe

# =========================
# Archives
# =========================
*.zip
*.tar.gz
*.rar
*.7z

# =========================
